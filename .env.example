# Telegram Configuration
TG_API_ID=your_api_id_here
TG_API_HASH=your_api_hash_here
TG_SESSION_NAME=tg_session

# Proxy for Telegram connection (optional)
# TG_PROXY=socks5://127.0.0.1:1080

# Channels to watch (comma-separated)
CHANNELS_TO_WATCH=["theblockbeats","Odaily_News","WatcherGuru"]

# Webhook forwarding URL
WEBHOOK_URL=http://127.0.0.1:8101/receive

# Sentiment API
SENTIMENT_API_URL=https://example.com
SENTIMENT_API_KEY=your_api_key_here

# News rater API (optional)
NEWS_RATER_URL=http://localhost:3099/api/agents/news-rater/run

# Server
HOST=0.0.0.0
PORT=8101

# Logging (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
